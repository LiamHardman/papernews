# Copy this file to `.env` and fill in. Docker Compose reads .env
# automatically and never logs its contents.

# Required: Anthropic API key. Create one at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# INGEST_INTERVAL_SECONDS=14400   # how often to re-ingest (default 4h)
# PAPERNEWS_WORKERS=8             # concurrent LLM batches
