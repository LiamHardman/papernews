# Copy this file to `.env` and fill in. Docker Compose reads .env
# automatically and never logs its contents.

# LLM backend: "anthropic" (default), "gemini", or "ollama"
LLM_BACKEND=anthropic
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=mistral

# Required when LLM_BACKEND=anthropic. Create a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Required when LLM_BACKEND=gemini. Create a key at
# https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash    # default; gemini-2.5-pro for higher quality

# Optional overrides
# PAPERNEWS_WORKERS=1             # set to 1 for Ollama/CPU (default 8 for Anthropic)
# OLLAMA_TIMEOUT=1800             # httpx timeout in seconds for Ollama requests (default 1800)

# Scheduling — pick one:
# INGEST_INTERVAL_SECONDS=14400   # every N seconds (default 4h)
# INGEST_SCHEDULE=07:00,18:00     # cron-style fixed times (overrides the interval)
# INGEST_TIMEZONE=Europe/London   # IANA tz, used with INGEST_SCHEDULE (default UTC)

# Post-ingest delivery hook (e.g. push the new PDF to a reMarkable).
# Drop the script in ./data/hooks/ and point this at it:
# POST_INGEST_HOOK=/data/hooks/push-to-remarkable.sh
# POST_INGEST_HOOK_TIMEOUT=300
